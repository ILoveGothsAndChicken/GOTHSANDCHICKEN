-- Services
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Settings
local settings = {
    Aimbot = true,
    Aiming = false,

    AimPart = "Head",
    TeamCheck = true,

    DrawFOV = true,
    FOVRadius = 200,
    FOVColor = Color3.fromRGB(255, 255, 255)
}

-- FOV Circle
local FOVCircle = Drawing.new("Circle")
FOVCircle.Radius = settings.FOVRadius
FOVCircle.Color = settings.FOVColor
FOVCircle.Thickness = 1
FOVCircle.Filled = false
FOVCircle.Transparency = 1
FOVCircle.Visible = true -- FORCE VISIBLE

-- Input Handling
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        settings.Aiming = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        settings.Aiming = false
    end
end)

-- Main Loop
RunService.RenderStepped:Connect(function()
    -- Update FOV Circle
    local mousePos = UIS:GetMouseLocation()
    FOVCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
    FOVCircle.Visible = settings.DrawFOV

    if not (settings.Aimbot and settings.Aiming) then
        return
    end

    local closestDistance = settings.FOVRadius
    local closestPart = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local targetPart = character:FindFirstChild(settings.AimPart)

            if humanoid and humanoid.Health > 0 and targetPart then
                if not settings.TeamCheck or player.Team ~= LocalPlayer.Team then
                    local screenPos, onScreen =
                        Camera:WorldToViewportPoint(targetPart.Position)

                    if onScreen then
                        local distance =
                            (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude

                        if distance < closestDistance then
                            closestDistance = distance
                            closestPart = targetPart
                        end
                    end
                end
            end
        end
    end

    if closestPart then
        Camera.CFrame = CFrame.new(
            Camera.CFrame.Position,
            closestPart.Position
        )
    end
end)
