-- Services 1
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer

-- Settings
local Settings = {
    Enabled = true,
    Aiming = false,
    AimPart = "Head",
    TeamCheck = true,

    FOVRadius = 200,
    FOVColor = Color3.fromRGB(255, 255, 255),
    FOVThickness = 2
}

-- GUI Setup
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local FOVCircle = Instance.new("Frame")
FOVCircle.Size = UDim2.fromOffset(Settings.FOVRadius * 2, Settings.FOVRadius * 2)
FOVCircle.BackgroundTransparency = 1
FOVCircle.AnchorPoint = Vector2.new(0.5, 0.5)
FOVCircle.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(1, 0)
UICorner.Parent = FOVCircle

local UIStroke = Instance.new("UIStroke")
UIStroke.Thickness = Settings.FOVThickness
UIStroke.Color = Settings.FOVColor
UIStroke.Parent = FOVCircle

-- Input
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        Settings.Aiming = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        Settings.Aiming = false
    end
end)

-- Main Loop
RunService.RenderStepped:Connect(function()
    local mousePos = UIS:GetMouseLocation()

    -- Move FOV Circle
    FOVCircle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)

    if not (Settings.Enabled and Settings.Aiming) then
        return
    end

    local closestDist = Settings.FOVRadius
    local closestPart = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local part = character:FindFirstChild(Settings.AimPart)

            if humanoid and humanoid.Health > 0 and part then
                if not Settings.TeamCheck or player.Team ~= LocalPlayer.Team then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)

                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closestPart = part
                        end
                    end
                end
            end
        end
    end

    if closestPart then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, closestPart.Position)
    end
end)
