-- This will print the name of every model you click on in the Output window
local Player = game:GetService("Players").LocalPlayer
local Mouse = Player:GetMouse()

Mouse.Button1Down:Connect(function()
    if Mouse.Target then
        print("You clicked on: " .. Mouse.Target.Name)
        if Mouse.Target.Parent then
            print("The Parent model is: " .. Mouse.Target.Parent.Name)
        end
    end
end)
