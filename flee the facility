local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local enabled = true -- The toggle state
local blueColor = Color3.fromRGB(0, 162, 255) -- Computer highlight color

-- Function to apply highlight to a specific object
local function applyHighlight(object, color)
    if object:FindFirstChild("ESPHighlight") then
        object.ESPHighlight:Destroy()
    end

    local h = Instance.new("Highlight")
    h.Name = "ESPHighlight"
    h.FillTransparency = 0.7
    h.OutlineTransparency = 0
    h.FillColor = color
    h.OutlineColor = color
    h.Enabled = enabled -- Sets it based on our toggle
    h.Parent = object
end

-- Setup for Players
local function setupPlayer(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(char)
        local color = player.TeamColor and player.TeamColor.Color or Color3.new(1, 1, 1)
        applyHighlight(char, color)
    end)
    if player.Character then
        local color = player.TeamColor and player.TeamColor.Color or Color3.new(1, 1, 1)
        applyHighlight(player.Character, color)
    end
end

-- Find and highlight computers
local function highlightComputers(root)
    for _, obj in ipairs(root:GetDescendants()) do
        if obj.Name == "ComputerTable" and (obj:IsA("Model") or obj:IsA("BasePart")) then
            applyHighlight(obj, blueColor)
        end
    end
end

-- WATCH FOR NEW ROUNDS/MAPS
-- This ensures that when a new map loads, the computers get highlighted
workspace.ChildAdded:Connect(function(child)
    -- Wait a tiny bit to ensure the map is fully loaded
    task.wait(1)
    highlightComputers(child)
end)

-- Toggle Function (F1)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    
    if input.KeyCode == Enum.KeyCode.F1 then
        enabled = not enabled
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Highlight") and desc.Name == "ESPHighlight" then
                desc.Enabled = enabled
            end
        end
    end
end)

-- Initial run for players and current objects
for _, p in ipairs(Players:GetPlayers()) do
    setupPlayer(p)
end
Players.PlayerAdded:Connect(setupPlayer)
highlightComputers(workspace)
