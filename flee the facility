local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function addHighlight(player)
    if player == LocalPlayer then return end

    local function setup(char)
        if char:FindFirstChild("ESPHighlight") then
            char.ESPHighlight:Destroy()
        end

        local h = Instance.new("Highlight")
        h.Name = "ESPHighlight"
        h.FillTransparency = 0.7
        h.OutlineTransparency = 0 -- 0 = solid outline
        
        h.OutlineColor = player.TeamColor and player.TeamColor.Color or Color3.new(1, 1, 1)
        h.FillColor = player.TeamColor and player.TeamColor.Color or Color3.new(1, 1, 1)
        
        h.Parent = char
    end

    if player.Character then
        setup(player.Character)
    end

    player.CharacterAdded:Connect(setup)
end

for _, p in ipairs(Players:GetPlayers()) do
    addHighlight(p)
end

Players.PlayerAdded:Connect(addHighlight)
