local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local playerEspEnabled = true
local computerEspEnabled = true
local blueColor = Color3.fromRGB(0, 162, 255) 

local function applyHighlight(object, color, espName, isEnabled)
    if not object then return end
    
    local h = object:FindFirstChild(espName)
    if not h then
        h = Instance.new("Highlight")
        h.Name = espName
        h.Parent = object
    end

    h.FillTransparency = 0.7
    h.OutlineTransparency = 0
    h.FillColor = color
    h.OutlineColor = color
    h.Enabled = isEnabled 
    h.Adornee = object 
end

-- Improved: Scan specifically for computers within any new object
local function scanForComputers(root)
    if root.Name == "ComputerTable" then
        applyHighlight(root, blueColor, "ComputerHighlight", computerEspEnabled)
    end
    for _, obj in ipairs(root:GetDescendants()) do
        if obj.Name == "ComputerTable" then
            applyHighlight(obj, blueColor, "ComputerHighlight", computerEspEnabled)
        end
    end
end

local function setupPlayer(player)
    if player == LocalPlayer then return end
    
    local function onCharAdded(char)
        task.wait(0.5)
        -- Added a check to ensure player is still in game
        if player.Parent then
            local color = (player.TeamColor and player.TeamColor.Color) or Color3.new(1, 1, 1)
            applyHighlight(char, color, "PlayerHighlight", playerEspEnabled)
        end
    end

    player.CharacterAdded:Connect(onCharAdded)
    if player.Character then onCharAdded(player.Character) end
end

--- ROUND PERSISTENCE LOGIC ---

-- This fires whenever the map (or anything else) is added to Workspace
workspace.DescendantAdded:Connect(function(descendant)
    -- Using task.defer allows the object to fully "arrive" before we check its name
    task.defer(function()
        if descendant.Name == "ComputerTable" then
            applyHighlight(descendant, blueColor, "ComputerHighlight", computerEspEnabled)
        end
    end)
end)

-------------------------------

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    
    if input.KeyCode == Enum.KeyCode.F1 then
        playerEspEnabled = not playerEspEnabled
        for _, desc in ipairs(game:GetDescendants()) do
            if desc:IsA("Highlight") and desc.Name == "PlayerHighlight" then
                desc.Enabled = playerEspEnabled
            end
        end
    elseif input.KeyCode == Enum.KeyCode.F2 then
        computerEspEnabled = not computerEspEnabled
        -- Update all existing computer highlights
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Highlight") and desc.Name == "ComputerHighlight" then
                desc.Enabled = computerEspEnabled
            end
        end
    end
end)

-- Initial Setup
for _, p in ipairs(Players:GetPlayers()) do
    setupPlayer(p)
end

Players.PlayerAdded:Connect(setupPlayer)
scanForComputers(workspace)
