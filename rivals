local Players = game:GetService("Players")

local RunService = game:GetService("RunService")

local UserInputService = game:GetService("UserInputService")

local Camera = workspace.CurrentCamera



local LocalPlayer = Players.LocalPlayer

local Mouse = LocalPlayer:GetMouse()



local aimEnabled = false

local aimSpeed = 0.1



-- INPUT TOGGLE (Right Mouse Button)

UserInputService.InputBegan:Connect(function(input, gp)

if gp then return end

if input.UserInputType == Enum.UserInputType.MouseButton2 then

aimEnabled = true

end

end)



UserInputService.InputEnded:Connect(function(input)

if input.UserInputType == Enum.UserInputType.MouseButton2 then

aimEnabled = false

end

end)



-- PLAYER HIGHLIGHT ESP

local function addHighlight(player)

if player == LocalPlayer then return end



local function setup(char)

local h = Instance.new("Highlight")

h.Name = "ESPHighlight"

h.FillTransparency = 0.7

h.OutlineTransparency = 0

h.OutlineColor = player.TeamColor.Color

h.FillColor = player.TeamColor.Color

h.Parent = char

end



if player.Character then

setup(player.Character)

end



player.CharacterAdded:Connect(setup)

end



for _, p in ipairs(Players:GetPlayers()) do

addHighlight(p)

end



Players.PlayerAdded:Connect(addHighlight)



-- GET CLOSEST PLAYER TO MOUSE

local function getClosestPlayer()

local closest = nil

local closestDist = math.huge



for _, p in ipairs(Players:GetPlayers()) do

if p ~= LocalPlayer and not LocalPlayer:IsFriendsWith(p.UserId) then

local char = p.Character

local hrp = char and char:FindFirstChild("HumanoidRootPart")

local hum = char and char:FindFirstChild("Humanoid")



if hrp and hum and hum.Health > 0 then

local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

if onScreen then

local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude

if dist < closestDist then

closestDist = dist

closest = p

end

end

end

end

end



return closest

end



-- AIM CAMERA LOOP

RunService.RenderStepped:Connect(function()

if aimEnabled then

local target = getClosestPlayer()

if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then

local pos = target.Character.HumanoidRootPart.Position

local camPos = Camera.CFrame.Position



local newCFrame = CFrame.new(camPos, pos)

Camera.CFrame = Camera.CFrame:Lerp(newCFrame, aimSpeed)

end

end

end)
